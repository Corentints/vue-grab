{
  "name": "vue-grab-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -F vue-grab build",
    "dev": "pnpm -F vue-grab dev",
    "example": "pnpm -F example-vite-vue dev",
    "example:nuxt": "pnpm -F example-nuxt4 dev",
    "docs": "pnpm -F vue-grab-docs dev",
    "lint": "eslint packages/vue-grab/src/",
    "lint:fix": "eslint packages/vue-grab/src/ --fix",
    "format": "prettier --write packages/ apps/",
    "typecheck": "pnpm -F vue-grab typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.1",
    "vue-eslint-parser": "^10.4.0"
  }
}
