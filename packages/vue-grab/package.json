{
  "name": "vue-grab",
  "version": "0.1.0",
  "description": "Cmd+C to select any Vue component and copy an AI-ready prompt to your clipboard",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./nuxt": {
      "types": "./dist/nuxt.d.ts",
      "import": "./dist/nuxt.js",
      "require": "./dist/nuxt.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit"
  },
  "keywords": [
    "vue",
    "nuxt",
    "devtools",
    "ai",
    "component-inspector",
    "copilot"
  ],
  "license": "MIT",
  "peerDependencies": {
    "vite-plugin-vue-inspector": "^5.0.0",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "nuxt": {
      "optional": true
    },
    "vite-plugin-vue-inspector": {
      "optional": true
    }
  },
  "dependencies": {
    "element-source": "^0.0.5"
  },
  "devDependencies": {
    "@nuxt/kit": "^3.0.0",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "nuxt": "^3.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vite-plugin-vue-inspector": "^5.4.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.0.0"
  }
}
